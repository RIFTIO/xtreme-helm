#!/bin/bash 

set -euo pipefail

# Xtreme Helm Deployment Script
# This script handles the installation, upgrade, and management of the Xtreme Helm chart
# Version: 1.0.0
# Author: Zhone Technologies
# Description: Automated deployment script for Xtreme platform using Helm
# Requirements: kubectl, helm, bash
# Usage: See help() function or run with --help

# Logging functions
log_info() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] INFO: $*" >&2
}

log_error() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] ERROR: $*" >&2
    exit 1
}

log_warn() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] WARN: $*" >&2
}

# Function to check Helm version
check_helm_version() {
    local version
    if ! version=$(helm version --short 2>/dev/null | cut -d'+' -f1 | sed 's/^v//'); then
        log_error "Helm is not installed or not accessible"
        exit 1
    fi
    
    if [ -z "$version" ]; then
        log_error "Unable to determine Helm version"
        exit 1
    fi
    
    log_info "Helm version: $version"
    
    local major=$(echo "$version" | cut -d. -f1)
    local minor=$(echo "$version" | cut -d. -f2)
    
    if [ "$major" -lt 3 ] || ([ "$major" -eq 3 ] && [ "$minor" -lt 20 ]); then
        log_warn "Helm version $version is below 3.20. Please upgrade to Helm 3.20 or later for best compatibility."
    fi
}

# Function to check Kubernetes type
check_k8s_type() {
    local server_version
    if ! server_version=$(kubectl version -o json 2>/dev/null | grep '"gitVersion"' | tail -1 | sed 's/.*"\(v[^"]*\)".*/\1/'); then
        log_error "Unable to determine Kubernetes server version"
        exit 1
    fi
    
    if [ -z "$server_version" ]; then
        log_error "Unable to retrieve Kubernetes server version"
        exit 1
    fi
    
    log_info "Kubernetes server version: $server_version"
    
    if echo "$server_version" | grep -q "+k3s"; then
        log_info "Detected Kubernetes type: K3s"
        is_k3s=true
    else
        log_info "Detected Kubernetes type: Standard Kubernetes"
        is_k3s=false
    fi
}

log_info "Starting Xtreme Helm Deployment Script v1.0.0"

# Check Helm version
check_helm_version

# Check Kubernetes type
check_k8s_type

# Default configuration
NS="demo"
env="prod"
chart="xtreme"
release="xtreme"
values=""
flags=""
init=true
install=true
clean=false
dryrun=false
check=true
limitresource=false
action=install
pullpolicy=false
storage=false
zms=false
ignore_old_crds=false

help() {
cat >&2 <<EOF
USAGE:
--chart path      helm chart. default is ./xtreme
--values path     values file. May be used more than once. default is environment-dependent (see below)
--ns namespace    override the namespace. Be consistent and use the same namespace for all commands including --clean
--release name    helm release name. default is xtreme
--dev             dev environment: DOCKERHUB_TOKEN optional, values default to values-aeo.yaml
--prod            prod environment (default): DOCKERHUB_TOKEN required, values default to values-aeo.yaml storage.yaml repos.yaml
--init            ONLY initialize infrastructure (namespace, CRDs). Only needs to be done once
--install         ONLY install
--upgrade         upgrade instead of install
--dry-run         do not install, just do a dry-run
--clean           clean up
--check           just check if service is up
--limitresource   enable resource limits and quotas (sets ensureResourceQuota=true)
--pullpolicy      set pull policy
--storage         set storage class
--zms             install zms also
--ignore-old-crds continue even if deprecated Strimzi CRD versions are found (use with caution)

Environment Variables:
  DOCKERHUB_TOKEN  Required for prod installs. Docker Hub authentication token for pulling images.

NOTE: that the default is to do init + install + check but if you specify a step, only that step is run

typical usage sequences
    --init, then --dry-run, then --install, then maybe --check, then --clean
OR
    none of the above :)
EOF
exit 1
}

while [[ $# -gt 0  && "$1" =~ ^-- ]]; do
    case $1 in
        --chart) chart=$2; shift;;
        --values) values="$values $2"; shift;;
        --ns) NS=$2; shift;;
        --release) release=$2; shift;;
        --dev) env="dev";;
        --prod) env="prod";;
        --init) install=false; check=false;;
        --install) init=false; check=false;;
        --upgrade) action=upgrade; init=false;;
        --dry-run) dryrun=true; init=false; install=false; check=false;;
        --clean) clean=true; init=false; install=false; check=false;;
        --check) install=false; init=false;;
        --limitresource) limitresource=true;;
        --pullpolicy) pullpolicy=true;;
        --storage) storage=true;;
        --zms) zms=true;;
        --ignore-old-crds) ignore_old_crds=true;;
        *) help;;
    esac
    shift
done
if [ $# -gt 0 ]; then
    help
fi

# Delete orphaned secrets before deployment
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
"${SCRIPT_DIR}/delete_orphaned_secrets.sh" "$NS"

if [ "$env" = "prod" ]; then
    default_values="values-aeo.yaml storage.yaml repos.yaml"
else
    default_values="values-aeo.yaml"
fi

if $is_k3s; then
    default_values="$default_values alias.yaml ports.yaml"
fi

if [ -z "$values" ]; then
    values="${default_values}"
fi

if $pullpolicy; then
  values="$values pull-policy.yaml"
fi

if $storage; then
  values="$values storage.yaml"
fi

if $zms; then
  flags="$flags --set global.install.zms=true"
fi

log_info "Configuration:"
log_info "  environment: $env"
log_info "  namespace: $NS"
log_info "  release: $release"
log_info "  install: $install"
log_info "  dry-run: $dryrun"
log_info "  check: $check"
log_info "  init: $init"
log_info "  clean: $clean"
log_info "  limitresource: $limitresource"
log_info "  chart: $chart"
log_info "  values: $values"

rc=0
for file in $chart $values; do
    if [ ! -e $file ]; then
        log_error "Required file not found: $file"
        rc=1
    fi
done
if [ $rc != 0 ]; then
    log_error "Exiting due to missing files"
    exit 1
fi

# Verify Kubernetes cluster connectivity
log_info "Checking Kubernetes cluster connectivity..."
nodes=$(kubectl get nodes  --no-headers  | wc -l)
if [ $? -ne 0 -o $nodes -lt 1 ]; then
  log_error "Failed to access Kubernetes cluster. Please check KUBECONFIG environment variable."
  exit 1
fi
log_info "Kubernetes cluster accessible with $nodes node(s)"

# Check that no Strimzi Kafka CRDs still carry pre-v1beta2 versions.
# Strimzi 0.50.1+ only supports v1beta2. Deploying with v1beta1/v1alpha1
# versions still served causes RBAC escalation failures and broken upgrades.
check_kafka_crd_versions() {
    log_info "Checking Strimzi Kafka CRD versions..."
    local found=0
    for crd in $(kubectl get crd -o name 2>/dev/null | grep "kafka.strimzi.io"); do
        crd_name="${crd#customresourcedefinition.apiextensions.k8s.io/}"
        old_versions=$(kubectl get crd "$crd_name" \
            -o jsonpath='{range .spec.versions[*]}{.name}{"\n"}{end}' 2>/dev/null \
            | grep -E "^v1beta1$|^v1alpha1$|^v1beta3$" || true)
        if [ -n "$old_versions" ]; then
            log_warn "CRD $crd_name still has deprecated versions: $(echo $old_versions | tr '\n' ' ')"
            found=1
        fi
    done
    if [ "$found" -ne 0 ]; then
        log_warn "One or more Strimzi CRDs have pre-v1beta2 versions still installed."
        log_warn "Remove them before deploying:"
        log_warn "  kubectl patch crd <name> --type=json -p='[{\"op\":\"remove\",\"path\":\"/spec/versions/N\"}]'"
        if $ignore_old_crds; then
            log_warn "Continuing anyway because --ignore-old-crds was specified."
        else
            log_error "Aborting. Re-run with --ignore-old-crds to deploy anyway (not recommended)."
            exit 1
        fi
    else
        log_info "All Strimzi Kafka CRDs are at v1beta2 only — OK"
    fi
}

if ! $dryrun && ! $clean && ( $init || $install ); then
    check_kafka_crd_versions
fi

# Validate DOCKERHUB_TOKEN: required in prod, optional in dev
if $install || $dryrun || $clean; then
  if [ -z "${DOCKERHUB_TOKEN:-}" ]; then
    if [ -f "dockerhub-token" ]; then
      DOCKERHUB_TOKEN=$(cat dockerhub-token)
      log_info "DOCKERHUB_TOKEN read from dockerhub-token file"
    elif [ "$env" = "prod" ]; then
      log_error "DOCKERHUB_TOKEN environment variable must be set or dockerhub-token file must be available for prod deployment"
      exit 1
    else
      log_warn "DOCKERHUB_TOKEN not set — proceeding without Docker Hub authentication (dev environment)"
      DOCKERHUB_TOKEN=""
    fi
  fi
fi

if $init; then
  
  log_info "Starting initialization..."
  for ns in ${NS} aeo-${NS}; do
    # Check if namespace exists
    if kubectl get ns $ns >/dev/null 2>&1; then
      log_info "Namespace $ns already exists"
      
      # Check and add labels if missing
      current_label=$(kubectl get ns $ns -o jsonpath='{.metadata.labels.app\.kubernetes\.io/managed-by}' 2>/dev/null || echo "")
      if [ "$current_label" != "Helm" ]; then
        log_info "Adding missing label to namespace: $ns"
        kubectl label namespace $ns app.kubernetes.io/managed-by=Helm --overwrite
      else
        log_info "Namespace $ns already has required label"
      fi
      
      # Check and add annotations if missing
      current_release_name=$(kubectl get ns $ns -o jsonpath='{.metadata.annotations.meta\.helm\.sh/release-name}' 2>/dev/null || echo "")
      current_release_ns=$(kubectl get ns $ns -o jsonpath='{.metadata.annotations.meta\.helm\.sh/release-namespace}' 2>/dev/null || echo "")
      if [ "$current_release_name" != "xtreme" ] || [ "$current_release_ns" != "default" ]; then
        log_info "Adding/updating annotations on namespace: $ns"
        kubectl annotate namespace $ns meta.helm.sh/release-name=xtreme meta.helm.sh/release-namespace=default --overwrite
      else
        log_info "Namespace $ns already has required annotations"
      fi
    else
      log_info "Creating namespace: $ns"
      kubectl create ns $ns
      log_info "Labeling and annotating namespace: $ns"
      kubectl label namespace $ns app.kubernetes.io/managed-by=Helm
      kubectl annotate namespace $ns meta.helm.sh/release-name=xtreme meta.helm.sh/release-namespace=default
    fi
  done

    # Check if chart directory exists, if not extract from archive
    # This is applicable only if charts are downloaded separately as tar.gz.
    if [ ! -d xtreme ]; then
       log_info "Expanding chart archive: $chart"
       tar xzf ${chart}
    fi

  log_info "Creating CRDs..."
  for f in xtreme/crds/*
  do 
    log_info "Applying CRD: $f"
    kubectl apply -f $f
  done
  log_info "Initialization completed"
fi

for file in $values; do
    flags="$flags -f $file"
done

if $limitresource; then
    flags="$flags --set global.ensureResourceQuota=true"
fi

flags="$flags --set global.namespace.name=$NS"
if [ -n "${DOCKERHUB_TOKEN:-}" ]; then
    flags="$flags --set global.dockerhubToken=$DOCKERHUB_TOKEN"
fi

if $dryrun; then
    log_info "Performing dry-run of Helm install..."
    log_info "Running: helm ${action} ${release} ${chart} $flags --dry-run"
    helm ${action} ${release} ${chart} $flags --dry-run
    log_info "Dry-run completed successfully"
    exit 0
fi

# Before a helm upgrade, check whether MongoDB's featureCompatibilityVersion is
# too old for the new image (MongoDB 8.0 requires FCV >= 7.0).  If it is, we
# wipe the StatefulSet and PVC so the upgrade starts with a clean database.
# The STS must be deleted first — deleting only the pod causes the STS to
# immediately recreate it and reattach to the (now-deleted) PVC.
handle_mongodb_upgrade() {
    local ns=$1
    local sts="rw-mongodb"
    local pvc="data-rw-mongodb-0"

    if ! kubectl get sts "$sts" -n "$ns" >/dev/null 2>&1; then
        return 0
    fi

    log_info "Checking MongoDB feature compatibility version in namespace $ns..."

    local needs_wipe=false

    # Try querying the live instance first (works when MongoDB is currently running).
    local fcv
    fcv=$(kubectl exec -n "$ns" "${sts}-0" -c mongodb -- \
        mongosh --port 8006 --quiet --eval \
        "db.adminCommand({getParameter:1,featureCompatibilityVersion:1}).featureCompatibilityVersion.version" \
        2>/dev/null | grep -E '^[0-9]+\.[0-9]+$' | tail -1 || true)

    if [ -n "$fcv" ]; then
        local major
        major=$(echo "$fcv" | cut -d. -f1)
        if [ "$major" -lt 7 ]; then
            log_warn "MongoDB FCV is $fcv — incompatible with MongoDB 8.0 (requires >= 7.0)"
            needs_wipe=true
        else
            log_info "MongoDB FCV $fcv is compatible — no migration needed"
        fi
    else
        # Fall back to log inspection when MongoDB is already in a crashloop.
        if kubectl logs "${sts}-0" -n "$ns" -c mongodb 2>/dev/null \
                | grep -q "Invalid feature compatibility version"; then
            log_warn "MongoDB is crash-looping due to incompatible feature compatibility version"
            needs_wipe=true
        else
            log_info "Could not determine MongoDB FCV — skipping migration check"
        fi
    fi

    if $needs_wipe; then
        log_warn "MongoDB data is incompatible with the new version and will be erased"
        log_info "Deleting MongoDB StatefulSet $sts in namespace $ns"
        kubectl delete sts "$sts" -n "$ns" --ignore-not-found=true
        log_info "Deleting MongoDB PVC $pvc in namespace $ns"
        kubectl delete pvc "$pvc" -n "$ns" --ignore-not-found=true
        log_info "Waiting for PVC deletion to complete..."
        kubectl wait --for=delete pvc/"$pvc" -n "$ns" --timeout=60s 2>/dev/null || true
        log_info "MongoDB cleared — fresh database will be initialized by the upgrade"
    fi
}

if $install; then
  log_info "Performing $action of Helm release..."

  # Check if release already exists
  if helm list -q --all-namespaces 2>/dev/null | grep -q "^${release}$"; then
    if [ "$action" = "install" ]; then
      log_info "Release ${release} already exists, switching to upgrade"
      action="upgrade"
    fi
  fi

  if [ "$action" = "upgrade" ]; then
      handle_mongodb_upgrade "$NS"
  fi

  log_info "Running: helm $action ${release} ${chart} $flags"
  helm $action ${release} ${chart} $flags
  log_info "Helm $action completed successfully"
fi

if $check; then
  log_info "Checking service availability..."
  log_info "Waiting for Xtreme ingress service to obtain IP/hostname"
  HN=""
  fqdn=false
  while [ -z "$HN" ]; do
    echo -n "." >&2
      sleep 1
      HN=$(kubectl get -n ${NS} svc/${release}-haproxy-ingress -o jsonpath='{.status.loadBalancer.ingress[0].hostname}')
      if [ -z "$HN" ]; then
        HN=$(kubectl get -n ${NS} svc/${release}-haproxy-ingress -o jsonpath='{.status.loadBalancer.ingress[0].ip}')
      else
        fqdn=true
      fi
  done
    log_info "Service hostname/IP: $HN"

    if $fqdn; then
        log_info "Waiting for DNS resolution"
        while ! host $HN; do
            sleep 1
        done
        log_info "Hostname $HN is resolving"
    fi

    log_info "Waiting for service to respond"
    while ! curl -kv https://$HN >/dev/null 2>&1; do
        echo -n "." >&2
        sleep 1
    done

    log_info "Waiting for launchpad to be ready"
    while curl -kv https://$HN 2>&1 | grep 'HTTP/2 503'; do
        sleep 10
    done

    log_info "SUCCESS: Service is ready at https://$HN"
fi

if $clean; then
  log_info "Starting comprehensive cleanup process..."
  log_info "Uninstalling Helm release: $release"
  helm uninstall ${release} || log_warn "Helm uninstall failed or release not found"
  
  log_info "Deleting CRDs..."
  for f in xtreme/crds/*
  do 
    if [ -f "$f" ]; then
      crd_name=$(basename "$f" .yaml)
      log_info "Deleting CRD: $crd_name"
      kubectl delete crd "$crd_name" --ignore-not-found=true || log_warn "Failed to delete CRD: $crd_name"
    fi
  done
  
  for ns in ${NS} aeo-${NS}; do
    log_info "Deleting namespace: $ns (this will remove all remaining resources)"
    kubectl delete ns $ns --ignore-not-found=true || log_warn "Failed to delete namespace: $ns"
  done
  
  log_info "Comprehensive cleanup completed successfully"
  exit 0
fi