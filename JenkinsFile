def devops_img_url  = "rt.cloud.dzsi.local/docker/devops:ub24"

node('ub24') {
    stage("checkout") {
        deleteDir()
        checkout scm
        sh "hostname"
        sh "id"
    }
    stage("build") {
        def build_img = docker.image(devops_img_url)
        build_img.pull()
        build_img.inside("-v /net:/net:shared") {
            sh "helm package xtreme"
       }
    }
    stage("publish") {
        environment {
            JFROG_CLI_OFFER_FROZEN_VERSION = true
            JFROG_CLI_AVOID_NEW_VERSION_WARNING = true
        }
        def build_img = docker.image(devops_img_url)
        build_img.pull()
        build_img.inside("-v /net:/net:shared") {
            def release = sh(returnStdout: true, script: "yq .version xtreme/Chart.yaml").trim().replaceAll('"', '')
            def xtreme_chart_url = "helm-dev/xtreme-${release}.tgz"
            print("release is ${release}")
            def chart_pathname = "xtreme-${release}.tgz"
            print("Xtreme chart is ${chart_pathname}")

            sh "id"
            sh "echo $HOME"
            sh "ls -la $HOME/.jfrog"
            sh "ls -l /home/jenkins/.jfrog"

            // Upload xtreme chart by branch name to helm-dev
            sh(returnStatus: true, script: "jf rt delete ${xtreme_chart_url} --quiet")
            sh(script: "jf rt u ${chart_pathname} ${xtreme_chart_url}")
            print("chart uploaded to ${xtreme_chart_url}")

            // publish to helm-release if and only if a tag of format v\d.\d.\d exists

            def tag=""
            try {
                sh "git pull --tags"
                tag = sh(returnStdout: true, script: "git describe --tags").trim()
            } catch(e) {
                tag = "NO TAGS FOUND"
            }
            if (tag ==~ /v\d+\.\d+\.\d+/ ) {
                xtreme_chart_url = "helm-release/xtreme-${release}.tgz"
                if (sh(returnStatus: true, script: "jf rt s ${xtreme_chart_url} | jq -re 'if ( map(.path) | length ) == 0 then empty else [] end'")) {
                    error "chart ${xtreme_chart_url} already exists in RT"
                }
                sh "jf rt u ${chart_pathname} ${xtreme_chart_url}"
                print("chart uploaded to ${xtreme_chart_url}")
            }
        }
    }
} // node
